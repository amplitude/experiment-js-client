{
  "extends": "../../tsconfig.json",
  "include": ["src/**/*.ts", "test/**/*.ts", "package.json"],
  "exclude": ["dist"],
  "typedocOptions": {
    "name": "Experiment JS Client Documentation",
    "entryPoints": ["./src/index.ts"],
    "categoryOrder": [
      "Core Usage",
      "Configuration",
      "Context Provider",
      "Types"
    ],
    "categorizeByGroup": false,
    "disableSources": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "excludeInternal": true,
    "hideGenerator": true,
    "includeVersion": true,
    "out": "../../docs",
    "readme": "none",
    "theme": "default"
  },
  "compilerOptions": {
    "lib": ["ES2019"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"]
    }
  }
}
