{
  "extends": "../../tsconfig.json",
  "include": ["src/**/*.ts", "test/**/*.ts", "package.json"],
  "exclude": ["dist"],
  "compilerOptions": {
    "noImplicitAny": false,
    "declaration": true,
    "declarationDir": "dist/types",
    "downlevelIteration": true,
    "strict": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "src/*": ["./src/*"]
    }
  }
}
