{
  "packages": ["packages/*"],
  "version": "independent",
  "npmClient": "yarn",
  "command": {
    "version": {
      "allowBranch": "main",
      "conventionalCommits": true,
      "createRelease": "github",
      "message": "chore(release): publish",
      "preid": "beta",
      "ignoreChanges": [
        "**/*.md",
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/test/**",
        "**/tests/**",
        "**/__tests__/**",
        "**/__mocks__/**",
        "**/*.snap",
        "**/example/**",
        "**/examples/**",
        "**/.eslintrc*",
        "**/eslint.config.*",
        "**/.prettierrc*",
        "**/.prettierignore",
        "**/jest.config.*",
        "**/jest.setup*",
        "**/commitlint.config.*"
      ]
    }
  }
}
